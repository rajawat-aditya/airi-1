# Copy this file to .env.local and fill in your values
# Never commit .env.local — it contains real secrets

# App
APP_BASE_URL=http://localhost:3000

# Auth0 — https://manage.auth0.com
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your_client_id
AUTH0_CLIENT_SECRET=your_client_secret
AUTH0_SECRET=generate_with: openssl rand -hex 32

# MongoDB Atlas connection string
APP_MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
